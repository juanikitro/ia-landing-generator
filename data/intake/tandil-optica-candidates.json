    "phone": "0249 442-4453",
    "opening_hours": {
      "raw": "Monday: 9:00 AM – 1:00 PM, 4:00 – 8:30 PM | Tuesday: 9:00 AM – 1:00 PM, 4:00 – 8:30 PM | Wednesday: 9:00 AM – 1:00 PM, 4:00 – 8:30 PM | Thursday: 9:00 AM – 1:00 PM, 4:00 – 8:30 PM | Friday: 9:00 AM – 1:00 PM, 4:00 – 8:30 PM | Saturday: 9:00 AM – 1:00 PM | Sunday: Closed",
